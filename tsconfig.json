{
  "compileOnSave": false,
  "exclude": [
    "projects/sonar/src/test-setup.ts",
    "projects/sonar/e2e/**"
  ],
  "compilerOptions": {
    "sourceMap": false,
    "declaration": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "typeRoots": [
      "node_modules/@types",
      "node_modules"
    ],
    "paths": {
      "@rero/ng-core": [
        "./node_modules/@rero/ng-core"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "useDefineForClassFields": false
  },
  "angularCompilerOptions": {
    "strictTemplates": true,
    "strictInjectionParameters": true
  }
}
